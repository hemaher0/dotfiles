#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
SOURCE_DIR="${DOTFILES_SOURCE_DIR:-$ROOT_DIR/home}"
DEV_DIR="$ROOT_DIR/.dev"
DEV_CONFIG="$ROOT_DIR/.local/dev.json"
DEFAULT_DEV_REF="dev"

usage() {
  cat <<'EOF'
Usage: dot <command>

Commands:
  install [--user]
             Install the complete dotfiles setup
  update     Pull the repository, then show component status
  tui        Open the Ratatui component dashboard
  doctor [--fix]
             Check local requirements and optionally repair user setup
  sync       Sync the chezmoi source directory
  dev-ref    Show or set the development Git ref
  dev-apply  Apply validated .dev changes to this checkout
  bootstrap  Run the repository bootstrap script
  help       Show this help
EOF
}

has_command() {
  if [ -x "$1" ] && case "$1" in */*) true ;; *) false ;; esac; then
    return 0
  fi

  command -v "$1" >/dev/null 2>&1
}

log() {
  printf '%s\n' "dotfiles: $*"
}

dev_ref() {
  if [ -n "${DOTFILES_DEV_REF:-}" ]; then
    printf '%s\n' "$DOTFILES_DEV_REF"
    return
  fi

  if [ -r "$DEV_CONFIG" ]; then
    configured_ref=$(sed -n 's/.*"ref"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$DEV_CONFIG" | sed -n '1p')
    if [ -n "$configured_ref" ]; then
      printf '%s\n' "$configured_ref"
      return
    fi
    log "warning: ignoring invalid development ref config: $DEV_CONFIG" >&2
  fi

  printf '%s\n' "$DEFAULT_DEV_REF"
}

set_dev_ref() {
  ref=$1

  if [ -z "$ref" ]; then
    log "dev-ref requires a Git ref"
    exit 1
  fi

  mkdir -p "$(dirname "$DEV_CONFIG")"
  escaped_ref=$(printf '%s' "$ref" | sed 's/\\/\\\\/g; s/"/\\"/g')
  {
    printf '{\n'
    printf '  "ref": "%s"\n' "$escaped_ref"
    printf '}\n'
  } > "$DEV_CONFIG"

  log "development ref set to $ref"
}

dev_ref_command() {
  case "$#" in
    0)
      dev_ref
      ;;
    1)
      set_dev_ref "$1"
      ;;
    *)
      log "usage: dot dev-ref [git-ref]"
      exit 1
      ;;
  esac
}

assert_git_root_clean() {
  dirty=$(git -C "$ROOT_DIR" status --porcelain)
  if [ -n "$dirty" ]; then
    log "root checkout has changes; commit, stash, or remove them before dev-apply"
    exit 1
  fi
}

assert_dev_root() {
  if [ ! -d "$DEV_DIR" ]; then
    log "development root is missing: $DEV_DIR"
    log "run: bin/dot-dev update --check"
    exit 1
  fi

  if ! git -C "$DEV_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    log "development root is not a git worktree: $DEV_DIR"
    exit 1
  fi
}

resolve_repo_path() {
  base=$1
  relative_path=$2

  case "$relative_path" in
    /*|..|../*|*/..|*/../*)
      log "refusing path outside repository: $relative_path"
      exit 1
      ;;
  esac

  printf '%s/%s\n' "$base" "$relative_path"
}

copy_dev_path_to_root() {
  relative_path=$1
  source_path=$(resolve_repo_path "$DEV_DIR" "$relative_path")
  target_path=$(resolve_repo_path "$ROOT_DIR" "$relative_path")
  mkdir -p "$(dirname "$target_path")"
  cp -f "$source_path" "$target_path"
}

remove_root_path() {
  relative_path=$1
  target_path=$(resolve_repo_path "$ROOT_DIR" "$relative_path")
  if [ -f "$target_path" ]; then
    rm -f "$target_path"
  fi
}

dev_apply() {
  assert_dev_root
  assert_git_root_clean

  root_head=$(git -C "$ROOT_DIR" rev-parse HEAD)

  git -C "$DEV_DIR" diff --name-only --diff-filter=D "$root_head" -- | while IFS= read -r path; do
    [ -n "$path" ] || continue
    log "remove: $path"
    remove_root_path "$path"
  done

  {
    git -C "$DEV_DIR" diff --name-only --diff-filter=ACMRT "$root_head" --
    git -C "$DEV_DIR" ls-files --others --exclude-standard
  } | while IFS= read -r path; do
    [ -n "$path" ] || continue
    log "apply: $path"
    copy_dev_path_to_root "$path"
  done

  log "development changes applied to root checkout"
}

is_wsl() {
  [ -r /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease
}

resolve_chezmoi() {
  if [ -n "${CHEZMOI:-}" ]; then
    printf '%s\n' "$CHEZMOI"
  elif has_command chezmoi; then
    printf '%s\n' "chezmoi"
  elif [ -x "$HOME/.local/bin/chezmoi" ]; then
    printf '%s\n' "$HOME/.local/bin/chezmoi"
  elif [ -x "$ROOT_DIR/.local/bin/chezmoi" ]; then
    printf '%s\n' "$ROOT_DIR/.local/bin/chezmoi"
  fi
}

chezmoi_resolver_source() {
  resolved_chezmoi=$1

  if [ -z "$resolved_chezmoi" ]; then
    printf '%s\n' "missing"
  elif [ -n "${CHEZMOI:-}" ] && [ "$resolved_chezmoi" = "$CHEZMOI" ]; then
    printf '%s\n' "env"
  elif [ "$resolved_chezmoi" = "chezmoi" ]; then
    printf '%s\n' "PATH"
  elif [ "$resolved_chezmoi" = "$HOME/.local/bin/chezmoi" ]; then
    printf '%s\n' "home-local"
  elif [ "$resolved_chezmoi" = "$ROOT_DIR/.local/bin/chezmoi" ]; then
    printf '%s\n' "repo-local"
  else
    printf '%s\n' "custom"
  fi
}

require_chezmoi() {
  CHEZMOI=$(resolve_chezmoi)

  if [ -z "$CHEZMOI" ] || ! has_command "$CHEZMOI"; then
    log "chezmoi is not installed"
    exit 1
  fi
}

sync_config() {
  require_chezmoi

  if [ ! -d "$SOURCE_DIR" ]; then
    log "chezmoi source directory is not ready: $SOURCE_DIR"
    return 1
  fi

  "$CHEZMOI" --source "$SOURCE_DIR" apply --force
}

sync_tmux_config() {
  require_chezmoi

  if [ ! -d "$SOURCE_DIR" ]; then
    log "chezmoi source directory is not ready: $SOURCE_DIR"
    return 1
  fi

  "$CHEZMOI" --source "$SOURCE_DIR" apply --force \
    "$HOME/.config/tmux/tmux.conf" \
    "$HOME/.config/tmux/tmux.conf.local"
}

refresh_user_path() {
  for path_dir in "$HOME/.local/bin" "$HOME/.cargo/bin" "$HOME/bin"; do
    if [ -d "$path_dir" ] && case ":${PATH:-}:" in *":$path_dir:"*) false ;; *) true ;; esac; then
      PATH="$path_dir:${PATH:-}"
      export PATH
    fi
  done
}

doctor_usage() {
  cat <<'EOF'
Usage: dot doctor [--fix]

Checks the local dotfiles setup. With --fix, repairs supported user-managed
components. It does not install OS packages.
EOF
}

install_usage() {
  cat <<'EOF'
Usage: dot install [--user]

Installs the complete dotfiles setup. The default install uses the detected
platform package manager and may ask for sudo. With --user, installs supported
components into the user profile without sudo.
EOF
}

sync_usage() {
  cat <<'EOF'
Usage: dot sync

Syncs the chezmoi source directory into the home directory.
EOF
}

update_usage() {
  cat <<'EOF'
Usage:
  dot update
  dot update --check
  dot update --raw
  dot update --sync <config-id>
  dot update --install <id>
  dot update --update <id>
  dot update --build <id>

Without options, pulls the repository, then prints a component status table.
--check prints the table without pulling. --raw prints machine-readable status
rows without pulling. --sync is for config components.
Action options run against the current checkout and then print the component
status table.
EOF
}

status_value() {
  value=$1

  if [ -n "$value" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "-"
  fi
}

command_version() {
  component_name=$1
  command_name=$2

  case "$component_name" in
    direnv)
      version_output=$("$command_name" version 2>/dev/null || true)
      ;;
    tmux)
      version_output=$("$command_name" -V 2>/dev/null || true)
      ;;
    *)
      version_output=$("$command_name" --version 2>/dev/null || true)
      ;;
  esac

  printf '%s\n' "$version_output" \
    | sed -n '1{s/^[^0-9]*//;s/[[:space:],].*$//;p;}'
}

repo_version() {
  repo_dir=$1

  if ! git -C "$repo_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return
  fi

  repo_branch=$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
  repo_sha=$(git -C "$repo_dir" rev-parse --short HEAD 2>/dev/null || true)

  if [ -n "$repo_branch" ] && [ -n "$repo_sha" ]; then
    printf '%s@%s\n' "$repo_branch" "$repo_sha"
  fi
}

first_available_command() {
  commands=$1
  old_ifs=$IFS
  IFS=,

  for command_name in $commands; do
    if has_command "$command_name"; then
      IFS=$old_ifs
      printf '%s\n' "$command_name"
      return 0
    fi
  done

  IFS=$old_ifs
  return 1
}

font_installed() {
  font_name=$1

  has_command fc-list && fc-list 2>/dev/null | grep -qi "$font_name"
}

font_current() {
  font_name=$1

  if has_command fc-match; then
    fc_match=$(fc-match "$font_name" 2>/dev/null || true)
    printf '%s\n' "$fc_match" | sed -n '1{s/:.*$//;p;}'
  fi
}

component_registry() {
  CHEZMOI=$(resolve_chezmoi)
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  antidote_home="${ANTIDOTE_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}/antidote}"
  nvim_lazy_dir="${XDG_DATA_HOME:-$HOME/.local/share}/nvim/lazy"

  cat <<EOF
repo|git|local|repo-dotfiles|dotfiles repo|git|repo|$ROOT_DIR
package|system|system|package-git|git|package|command|git
package|system|system|package-chezmoi|chezmoi|package|command|$CHEZMOI
package|source|local|package-zsh|zsh|source|command|zsh
package|source|local|package-tmux|tmux|source|command|tmux
package|prebuilt|local|package-nvim|nvim|prebuilt|command|nvim
dependency|rustup|local|dependency-rust|Rust toolchain|rustup|all-commands|rustc,cargo
dependency|source|local|dependency-ncurses|ncurses|source|ncurses|${USER_PREFIX:-$HOME/.local}
dependency|source|local|dependency-libevent|libevent|source|libevent|${USER_PREFIX:-$HOME/.local}
dependency|system|system|dependency-downloader|curl or wget|package|any-command|curl,wget
tool|user-bin|local|tool-zoxide|zoxide|prebuilt|command|zoxide
tool|user-bin|local|tool-direnv|direnv|prebuilt|command|direnv
config|chezmoi|local|config-zshrc|synced zshrc|chezmoi|file|$HOME/.zshrc
config|chezmoi|local|config-zshenv|synced zshenv|chezmoi|file|$HOME/.zshenv
config|chezmoi|local|config-p10k|synced Powerlevel10k config|chezmoi|file|$HOME/.p10k.zsh
config|chezmoi|local|config-nvim|synced Neovim config|chezmoi|file|$HOME/.config/nvim/init.lua
config|chezmoi|local|config-wezterm|synced WezTerm config|chezmoi|file|$HOME/.config/wezterm/wezterm.lua
config|tmux|local|config-tmux|managed tmux config|chezmoi|symlink|$HOME/.config/tmux/tmux.conf
config|tmux|local|config-tmux-local|managed tmux local config|chezmoi|file|$HOME/.config/tmux/tmux.conf.local
plugin|tmux|local|plugin-tmux|tmux plugins|git|group|tmux
plugin|tmux|local|plugin-tmux-oh-my|Oh my tmux checkout|git|dir|${OH_MY_TMUX_DIR:-$HOME/.local/share/oh-my-tmux}
plugin|zsh|local|plugin-zsh|zsh plugins|antidote|group|zsh
plugin|zsh|local|plugin-zsh-antidote|Antidote|git|file|$antidote_dir/antidote.zsh
plugin|zsh|local|plugin-zsh-manifest|zsh plugin manifest|chezmoi|file|$HOME/.config/zsh/plugins.txt
plugin|zsh|local|plugin-zsh-powerlevel10k|zsh plugin: powerlevel10k|antidote|dir|$antidote_home/github.com/romkatv/powerlevel10k
plugin|zsh|local|plugin-zsh-forgit|zsh plugin: forgit|antidote|dir|$antidote_home/github.com/wfxr/forgit
plugin|zsh|local|plugin-zsh-vi-mode|zsh plugin: zsh-vi-mode|antidote|dir|$antidote_home/github.com/jeffreytse/zsh-vi-mode
plugin|nvim|local|plugin-nvim|Neovim plugins|lazy.nvim|group|nvim
plugin|nvim|local|plugin-nvim-lazy|Neovim plugin: lazy.nvim|lazy.nvim|dir|$nvim_lazy_dir/lazy.nvim
plugin|nvim|local|plugin-nvim-smart-splits|Neovim plugin: smart-splits.nvim|lazy.nvim|dir|$nvim_lazy_dir/smart-splits.nvim
plugin|nvim|local|plugin-nvim-blink-cmp|Neovim plugin: blink.cmp|lazy.nvim|dir|$nvim_lazy_dir/blink.cmp
plugin|nvim|local|plugin-nvim-neo-tree|Neovim plugin: neo-tree.nvim|lazy.nvim|dir|$nvim_lazy_dir/neo-tree.nvim
plugin|nvim|local|plugin-nvim-treesitter|Neovim plugin: nvim-treesitter|lazy.nvim|dir|$nvim_lazy_dir/nvim-treesitter
plugin|nvim|local|plugin-nvim-mason|Neovim plugin: mason.nvim|lazy.nvim|dir|$nvim_lazy_dir/mason.nvim
EOF

  printf '%s\n' "font|fontconfig|local|font-red-hat-mono|Red Hat Mono|fontconfig|font|Red Hat Mono"
  printf '%s\n' "font|fontconfig|local|font-d2coding-ligature|D2CodingLigature Nerd Font|fontconfig|font|D2CodingLigature Nerd Font"
}

component_policy() {
  component_id=$1
  kind=$2
  target=$3

  case "$component_id" in
    package-chezmoi)
      printf '%s\n' "resolver:CHEZMOI,PATH,home-local,repo-local"
      ;;
    dependency-downloader)
      printf '%s\n' "preferred:curl; alternative:wget"
      ;;
    *)
      case "$kind" in
        any-command)
          printf 'first-available:%s\n' "$target"
          ;;
        *)
          printf '%s\n' "-"
          ;;
      esac
      ;;
  esac
}

component_relation() {
  component_id=$1
  current=$2

  case "$component_id:$current" in
    config-tmux:target-missing)
      printf '%s\n' "requires:plugin-tmux"
      ;;
    *)
      printf '%s\n' "-"
      ;;
  esac
}

ncurses_current() {
  user_prefix=$1

  for config_tool in "$user_prefix/bin/ncursesw6-config" "$user_prefix/bin/ncurses6-config"; do
    if [ -x "$config_tool" ]; then
      "$config_tool" --version 2>/dev/null || true
      return
    fi
  done

  for lib_dir in "$user_prefix/lib" "$user_prefix/lib64"; do
    for lib_name in libncursesw.so libncursesw.a libncurses.so libncurses.a; do
      if [ -r "$lib_dir/$lib_name" ]; then
        printf '%s\n' "present"
        return
      fi
    done
  done
}

libevent_current() {
  user_prefix=$1

  if [ -x "$user_prefix/bin/libevent-config" ]; then
    "$user_prefix/bin/libevent-config" --version 2>/dev/null || true
    return
  fi

  for lib_dir in "$user_prefix/lib" "$user_prefix/lib64"; do
    for lib_name in libevent.so libevent.a; do
      if [ -r "$lib_dir/$lib_name" ]; then
        printf '%s\n' "present"
        return
      fi
    done
  done
}

first_command_version() {
  commands=$1
  old_ifs=$IFS
  IFS=,

  for command_name in $commands; do
    if has_command "$command_name"; then
      IFS=$old_ifs
      command_version "$command_name" "$command_name"
      return 0
    fi
  done

  IFS=$old_ifs
  return 1
}

plugin_group_status() {
  group_name=$1
  missing_count=0
  total_count=0
  registry_rows=$(component_registry)

  while IFS='|' read -r category group scope component_id component_name method kind target; do
    [ "$category:$group:$scope" = "plugin:$group_name:local" ] || continue
    [ "$kind" != "group" ] || continue

    total_count=$((total_count + 1))
    case "$kind" in
      file)
        [ -r "$target" ] || missing_count=$((missing_count + 1))
        ;;
      dir)
        [ -d "$target" ] || missing_count=$((missing_count + 1))
        ;;
      *)
        missing_count=$((missing_count + 1))
        ;;
    esac
  done <<EOF
$registry_rows
EOF

  if [ "$total_count" -eq 0 ]; then
    printf '%s|%s\n' "unknown" "no leaf components"
  elif [ "$missing_count" -eq 0 ]; then
    printf '%s|%s\n' "ok" "$total_count present"
  else
    printf '%s|%s\n' "missing" "$missing_count/$total_count missing"
  fi
}

plugin_manager_id() {
  group_name=$1

  case "$group_name" in
    nvim)
      printf '%s\n' "plugin-nvim"
      ;;
    zsh)
      printf '%s\n' "plugin-zsh"
      ;;
    tmux)
      printf '%s\n' "plugin-tmux"
      ;;
    *)
      return 1
      ;;
  esac
}

default_action_kind() {
  category=$1
  group=$2

  case "$category:$group" in
    config:*)
      printf '%s\n' "sync"
      ;;
    *)
      printf '%s\n' "install"
      ;;
  esac
}

component_executor_target() {
  component_id=$1
  target=$2

  case "$component_id" in
    dependency-rust)
      printf '%s\n' "rust"
      ;;
    dependency-ncurses)
      printf '%s\n' "ncurses"
      ;;
    dependency-libevent)
      printf '%s\n' "libevent"
      ;;
    plugin-nvim)
      printf '%s\n' "nvim"
      ;;
    plugin-zsh)
      printf '%s\n' "zsh"
      ;;
    plugin-tmux)
      printf '%s\n' "tmux"
      ;;
    *)
      printf '%s\n' "$target"
      ;;
  esac
}

render_action_command() {
  action_kind=$1
  action_target=$2

  if [ "$action_kind" = "none" ] || [ -z "$action_target" ]; then
    printf '%s\n' "-"
  else
    printf 'bin/dot update --%s %s\n' "$action_kind" "$action_target"
  fi
}

component_status_fields() {
  category=$1
  group=$2
  scope=$3
  component_id=$4
  component_name=$5
  method=$6
  kind=$7
  target=$8
  status=missing
  current=
  policy=$(component_policy "$component_id" "$kind" "$target")
  action_kind=$(default_action_kind "$category" "$group")
  action_target=$component_id

  if [ "$category:$group" = "plugin:zsh" ] && [ "$component_id" = "plugin-zsh-manifest" ]; then
    action_kind=sync
  fi

  case "$component_id" in
    plugin-zsh-*|plugin-tmux-*)
      action_kind=none
      action_target=
      ;;
  esac

  case "$kind" in
    group)
      group_status=$(plugin_group_status "$target")
      status=${group_status%%|*}
      current=${group_status#*|}
      if [ "$status" = "ok" ]; then
        action_kind=none
        action_target=
      fi
      ;;
    repo)
      if current=$(repo_version "$target"); then
        status=ok
        action_kind=none
        action_target=
      fi
      ;;
    ncurses)
      current=$(ncurses_current "$target")
      if [ -n "$current" ]; then
        status=ok
        action_kind=none
        action_target=
      fi
      ;;
    libevent)
      current=$(libevent_current "$target")
      if [ -n "$current" ]; then
        status=ok
        action_kind=none
        action_target=
      fi
      ;;
    command)
      if has_command "$target"; then
        status=ok
        case "$component_id" in
          package-chezmoi)
            current="$(chezmoi_resolver_source "$target"):$target"
            ;;
          *)
            current=$(command_version "$component_name" "$target")
            ;;
        esac
        action_kind=none
        action_target=
      fi
      ;;
    all-commands)
      missing_command=0
      old_ifs=$IFS
      IFS=,
      for command_name in $target; do
        if ! has_command "$command_name"; then
          missing_command=1
        fi
      done
      IFS=$old_ifs
      if [ "$missing_command" -eq 0 ]; then
        status=ok
        current=$(first_command_version "$target")
        action_kind=none
        action_target=
      fi
      ;;
    any-command)
      if command_name=$(first_available_command "$target"); then
        status=ok
        current=$command_name
        action_kind=none
        action_target=
      fi
      ;;
    file)
      if [ -r "$target" ]; then
        status=ok
        current=present
        action_kind=none
        action_target=
      fi
      ;;
    symlink)
      if [ -L "$target" ] && [ -r "$target" ]; then
        status=ok
        current=present
        action_kind=none
        action_target=
      elif [ -L "$target" ]; then
        current=target-missing
        case "$component_id" in
          config-tmux)
            action_kind=install
            action_target=plugin-tmux
            ;;
        esac
      fi
      ;;
    dir)
      if [ -d "$target" ]; then
        status=ok
        current=present
        action_kind=none
        action_target=
      fi
      ;;
    font)
      if ! has_command fc-list; then
        status=unknown
        action_kind=install
        action_target=$component_id
      elif font_installed "$target"; then
        status=ok
        current=$(font_current "$target")
        action_kind=none
        action_target=
      fi
      ;;
  esac

  if [ "$category" = "plugin" ] && [ "$kind" != "group" ]; then
    if manager_id=$(plugin_manager_id "$group"); then
      if [ "$status" != "ok" ] && [ -z "$current" ]; then
        current="managed by $manager_id"
      fi
    fi

    case "$group:$status" in
      nvim:ok)
        action_kind=none
        action_target=
        ;;
      nvim:*)
        action_kind=install
        action_target=$component_id
        ;;
      *)
        action_kind=none
        action_target=
        ;;
    esac
  fi
  relation=$(component_relation "$component_id" "$current")

  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
    "$status" "$category" "$group" "$scope" "$component_id" "$component_name" \
    "$method" "$current" "$policy" "$relation" "$action_kind" "$action_target"
}

component_base_rows() {
  component_registry | while IFS='|' read -r category group scope component_id component_name method kind target; do
    component_status_fields "$category" "$group" "$scope" "$component_id" "$component_name" "$method" "$kind" "$target"
  done
}

component_all_install_row() {
  base_rows=$(component_base_rows)
  missing_count=0

  while IFS='|' read -r status category group scope component_id component_name method current policy relation action_kind action_target; do
    [ -n "$status" ] || continue

    case "$status" in
      missing|unknown)
        missing_count=$((missing_count + 1))
        ;;
    esac
  done <<EOF
$base_rows
EOF

  if [ "$missing_count" -eq 0 ]; then
    status=ok
    current="all present"
  else
    status=missing
    current="$missing_count need action"
  fi

  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
    "$status" "all" "setup" "local" "all-install" "complete dotfiles setup" \
    "installer" "$current" "-" "-" "install" "all-install"
}

component_rows() {
  component_all_install_row
  component_base_rows
}

component_status_row() {
  status=$1
  category=$2
  group=$3
  scope=$4
  component_id=$5
  component_name=$6
  method=$7
  current=$8
  policy=$9
  relation=${10:-}
  action_kind=${11:-none}
  action_target=${12:-}
  action=$(render_action_command "$action_kind" "$action_target")

  printf '%-8s %-12s %-12s %-7s %-28s %-34s %-14s %-16s %-36s %-24s %s\n' \
    "$status" "$category" "$group" "$scope" "$component_id" "$component_name" \
    "$method" "$(status_value "$current")" "$(status_value "$policy")" \
    "$(status_value "$relation")" "$action"
}

component_status_table() {
  printf '%-8s %-12s %-12s %-7s %-28s %-34s %-14s %-16s %-36s %-24s %s\n' \
    "STATUS" "CATEGORY" "GROUP" "SCOPE" "ID" "COMPONENT" "METHOD" "CURRENT" "POLICY" "RELATION" "ACTION"
  printf '%-8s %-12s %-12s %-7s %-28s %-34s %-14s %-16s %-36s %-24s %s\n' \
    "------" "--------" "-----" "-----" "--" "---------" "------" "-------" "------" "--------" "------"

  component_rows | while IFS='|' read -r status category group scope component_id component_name method current policy relation action_kind action_target; do
    component_status_row "$status" "$category" "$group" "$scope" "$component_id" \
      "$component_name" "$method" "$current" "$policy" "$relation" "$action_kind" "$action_target"
  done
}

component_row() {
  component_id=$1

  if [ "$component_id" = "all-install" ]; then
    printf '%s\n' "all|setup|local|all-install|complete dotfiles setup|installer|aggregate|all"
    return 0
  fi

  component_registry | awk -F '|' -v component_id="$component_id" '
    $4 == component_id {
      print
      found = 1
    }
    END {
      exit found ? 0 : 1
    }
  '
}

component_status_row_by_id() {
  component_id=$1

  component_rows | awk -F '|' -v component_id="$component_id" '
    $5 == component_id {
      print
      found = 1
    }
    END {
      exit found ? 0 : 1
    }
  '
}

list_component_ids() {
  printf '%s\n' "all-install"
  component_registry | awk -F '|' '{ print $4 }'
}

require_component_id() {
  component_id=$1

  if component_row "$component_id" >/dev/null; then
    return 0
  fi

  log "unknown component id: $component_id"
  log "known component ids:"
  list_component_ids | sed 's/^/  /'
  return 1
}

run_tui() {
  manifest_path="$ROOT_DIR/tools/dot-tui/Cargo.toml"
  release_binary="$ROOT_DIR/tools/dot-tui/target/release/dot-tui"
  debug_binary="$ROOT_DIR/tools/dot-tui/target/debug/dot-tui"

  if [ -x "$release_binary" ]; then
    "$release_binary" "$ROOT_DIR"
  elif [ -x "$debug_binary" ]; then
    "$debug_binary" "$ROOT_DIR"
  elif has_command cargo; then
    log "building and running Ratatui dashboard"
    cargo run --quiet --manifest-path "$manifest_path" -- "$ROOT_DIR"
  else
    log "cargo is required to build the Ratatui dashboard"
    log "run: bin/dot update --install dependency-rust"
    return 1
  fi
}

pull_repository() {
  if ! has_command git; then
    log "git is required for update"
    exit 1
  fi

  log "updating repository"
  git -C "$ROOT_DIR" pull --ff-only
}

run_user_package_component() {
  component_name=$1

  run_packages "user-$component_name"
}

run_forced_user_package_component() {
  component_name=$1
  old_force=${DOTFILES_FORCE_USER_INSTALL:-}

  DOTFILES_FORCE_USER_INSTALL=1
  export DOTFILES_FORCE_USER_INSTALL
  run_user_package_component "$component_name"

  if [ -n "$old_force" ]; then
    DOTFILES_FORCE_USER_INSTALL=$old_force
    export DOTFILES_FORCE_USER_INSTALL
  else
    unset DOTFILES_FORCE_USER_INSTALL
  fi
}

unsupported_component_action() {
  action_name=$1
  component_id=$2

  log "$action_name is not supported for component: $component_id"
  return 1
}

managed_component_action() {
  action_name=$1
  component_id=$2
  group_name=$3

  if [ "$action_name" = "sync" ]; then
    log "sync is only supported for config components: $component_id"
    return 1
  fi

  if manager_id=$(plugin_manager_id "$group_name"); then
    log "$action_name is managed by group component: $manager_id"
    log "use: bin/dot update --$action_name $manager_id"
  else
    log "$action_name is not supported for component: $component_id"
  fi
  return 1
}

run_all_component_action() {
  action_name=$1
  component_id=$2

  case "$action_name" in
    install)
      install_setup
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_repo_component_action() {
  action_name=$1
  component_id=$2

  case "$action_name" in
    install|update)
      pull_repository
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_package_like_component_action() {
  action_name=$1
  component_id=$2
  group=$3
  scope=$4
  target=$5
  executor_target=$(component_executor_target "$component_id" "$target")

  case "$action_name:$group:$scope" in
    install:system:system)
      run_packages install
      ;;
    update:system:system)
      run_packages upgrade
      ;;
    install:*:local)
      run_user_package_component "$executor_target"
      refresh_user_path
      ;;
    update:*:local)
      run_forced_user_package_component "$executor_target"
      refresh_user_path
      ;;
    build:source:local)
      run_forced_user_package_component "$executor_target"
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_tool_component_action() {
  action_name=$1
  component_id=$2
  target=$3

  case "$action_name" in
    install|update)
      run_tools "$action_name" "$target"
      refresh_user_path
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_config_component_action() {
  action_name=$1
  component_id=$2
  group=$3

  case "$action_name:$group" in
    install:tmux|update:tmux|sync:tmux)
      sync_tmux_config
      refresh_user_path
      ;;
    install:chezmoi|update:chezmoi|sync:chezmoi)
      sync_config
      refresh_user_path
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_plugin_component_action() {
  action_name=$1
  component_id=$2
  group=$3
  kind=$4

  if [ "$kind" != "group" ]; then
    case "$action_name:$group" in
      install:nvim)
        install_nvim_setup "$component_id"
        ;;
      update:nvim)
        update_nvim_setup "$component_id"
        ;;
      *)
        managed_component_action "$action_name" "$component_id" "$group"
        ;;
    esac
    return
  fi

  case "$action_name:$group" in
    install:zsh)
      install_zsh_setup
      ;;
    update:zsh)
      update_zsh_setup
      ;;
    install:nvim)
      install_nvim_setup
      ;;
    update:nvim)
      update_nvim_setup
      ;;
    install:tmux)
      install_tmux_setup
      sync_tmux_config
      ;;
    update:tmux)
      update_tmux_setup
      ;;
    sync:*)
      log "sync is only supported for config components: $component_id"
      return 1
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_font_component_action() {
  action_name=$1
  component_id=$2

  case "$action_name" in
    install|update)
      run_fonts "$action_name" "$component_id"
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

run_component_category_action() {
  action_name=$1
  category=$2
  group=$3
  scope=$4
  component_id=$5
  kind=$6
  target=$7

  case "$category" in
    all)
      run_all_component_action "$action_name" "$component_id"
      ;;
    repo)
      run_repo_component_action "$action_name" "$component_id"
      ;;
    package|dependency)
      run_package_like_component_action "$action_name" "$component_id" "$group" "$scope" "$target"
      ;;
    tool)
      run_tool_component_action "$action_name" "$component_id" "$target"
      ;;
    config)
      run_config_component_action "$action_name" "$component_id" "$group"
      ;;
    plugin)
      run_plugin_component_action "$action_name" "$component_id" "$group" "$kind"
      ;;
    font)
      run_font_component_action "$action_name" "$component_id"
      ;;
    *)
      unsupported_component_action "$action_name" "$component_id"
      ;;
  esac
}

install_component() {
  run_component_action install "$1"
}

update_component() {
  run_component_action update "$1"
}

sync_component() {
  run_component_action sync "$1"
}

build_component() {
  run_component_action build "$1"
}

run_component_action() {
  action_name=$1
  component_id=$2

  case "$action_name" in
    sync|install|update|build)
      ;;
    *)
      log "unknown update action: $action_name"
      return 1
      ;;
  esac

  if ! component_row=$(component_row "$component_id"); then
    log "unknown component id: $component_id"
    log "known component ids:"
    list_component_ids | sed 's/^/  /'
    return 1
  fi

  IFS='|' read -r category group scope row_id component_name method kind target <<EOF
$component_row
EOF

  log "$action_name component: $component_id"
  if ! run_component_category_action "$action_name" "$category" "$group" "$scope" "$row_id" "$kind" "$target"; then
    return 1
  fi

  refresh_user_path
  log "component status"
  component_status_table
}

mark_missing() {
  log "missing: $1"
  failed=1
}

mark_warning() {
  log "warning: $1"
}

check_command_status() {
  command_name=$1
  install_group=$2

  if has_command "$command_name"; then
    log "ok: command $command_name"
    return
  fi

  mark_missing "command $command_name"

  case "$install_group" in
    packages) need_packages=1 ;;
    tools) need_tools=1 ;;
    none) ;;
  esac
}

check_file_status() {
  file_path=$1
  description=$2

  if [ -r "$file_path" ]; then
    log "ok: $description"
  else
    mark_missing "$description"
    need_sync=1
  fi
}

check_user_tool_status() {
  command_name=$1
  tool_path="$HOME/.local/bin/$command_name"

  if has_command "$command_name"; then
    log "ok: command $command_name"
  elif [ -x "$tool_path" ]; then
    mark_missing "command $command_name is installed but not on PATH: $tool_path"
    need_sync=1
  else
    mark_missing "command $command_name"
    need_tools=1
  fi
}

check_fontconfig_font() {
  font_name=$1

  if fc-list 2>/dev/null | grep -qi "$font_name"; then
    log "ok: font $font_name"
  else
    mark_missing "font $font_name"
    need_fonts=1
  fi
}

check_fonts_status() {
  if has_command fc-list; then
    check_fontconfig_font "Red Hat Mono"
    check_fontconfig_font "D2CodingLigature Nerd Font"
  else
    mark_missing "command fc-list"
    need_packages=1
    need_fonts=1
  fi

  if has_command wezterm; then
    wezterm_fonts=$(wezterm ls-fonts 2>/dev/null || true)
    if printf '%s\n' "$wezterm_fonts" | grep -q "Red Hat Mono" \
      && printf '%s\n' "$wezterm_fonts" | grep -q "D2CodingLigature Nerd Font"; then
      log "ok: WezTerm font fallback"
    else
      mark_warning "WezTerm did not report both preferred fonts"
    fi
  fi
}

check_zsh_plugins_status() {
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  antidote_home="${ANTIDOTE_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}/antidote}"

  if [ -r "$antidote_dir/antidote.zsh" ]; then
    log "ok: Antidote script"
  else
    mark_missing "Antidote script"
    need_zsh_plugins=1
  fi

  check_file_status "$HOME/.config/zsh/plugins.txt" "zsh plugin manifest"

  for bundle in \
    github.com/romkatv/powerlevel10k \
    github.com/wfxr/forgit \
    github.com/jeffreytse/zsh-vi-mode
  do
    if [ -d "$antidote_home/$bundle" ]; then
      log "ok: zsh bundle $bundle"
    else
      mark_missing "zsh bundle $bundle"
      need_zsh_plugins=1
    fi
  done
}

check_nvim_plugins_status() {
  nvim_lazy_dir="${XDG_DATA_HOME:-$HOME/.local/share}/nvim/lazy"

  for plugin in \
    lazy.nvim \
    smart-splits.nvim \
    blink.cmp \
    neo-tree.nvim \
    nvim-treesitter \
    mason.nvim
  do
    if [ -d "$nvim_lazy_dir/$plugin" ]; then
      log "ok: Neovim plugin $plugin"
    else
      mark_missing "Neovim plugin $plugin"
      need_nvim_plugins=1
    fi
  done
}

check_tmux_status() {
  oh_my_tmux_dir="${OH_MY_TMUX_DIR:-$HOME/.local/share/oh-my-tmux}"

  if has_command tmux; then
    log "ok: command tmux"
  else
    mark_missing "command tmux"
    need_tmux=1
  fi

  if [ -d "$oh_my_tmux_dir/.git" ]; then
    log "ok: Oh my tmux checkout"
  else
    mark_missing "Oh my tmux checkout"
    need_tmux=1
  fi

  if [ -L "$HOME/.config/tmux/tmux.conf" ] && [ -r "$HOME/.config/tmux/tmux.conf" ]; then
    log "ok: managed tmux config"
  else
    mark_missing "managed tmux config"
    need_tmux=1
  fi

  if [ -r "$HOME/.config/tmux/tmux.conf.local" ]; then
    log "ok: managed tmux local config"
  else
    mark_missing "managed tmux local config"
    need_tmux=1
  fi
}

check_wezterm_status() {
  if ! has_command wezterm; then
    mark_warning "wezterm command is not installed in this environment"
    return
  fi

  log "ok: command wezterm"

  if wezterm cli adjust-pane-size --help >/dev/null 2>&1; then
    log "ok: WezTerm pane resize CLI"
  else
    mark_missing "WezTerm pane resize CLI"
  fi

  if wezterm show-keys --lua >/dev/null 2>&1; then
    log "ok: WezTerm config loads"
  else
    mark_missing "WezTerm config loads"
  fi
}

doctor_check() {
  failed=0
  need_sync=0
  need_fonts=0
  need_nvim_plugins=0
  need_packages=0
  need_tmux=0
  need_tools=0
  need_zsh_plugins=0

  refresh_user_path
  CHEZMOI=$(resolve_chezmoi)

  check_command_status git packages
  check_command_status "$CHEZMOI" packages
  check_command_status zsh packages
  check_command_status nvim packages
  check_command_status rustc packages
  check_command_status cargo packages

  if has_command curl || has_command wget; then
    log "ok: curl or wget"
  else
    mark_missing "curl or wget"
    need_packages=1
  fi

  if [ -d "$SOURCE_DIR" ]; then
    log "ok: chezmoi source $SOURCE_DIR"
  else
    mark_missing "chezmoi source $SOURCE_DIR"
  fi

  check_file_status "$HOME/.zshrc" "synced zshrc"
  check_file_status "$HOME/.zshenv" "synced zshenv"
  check_file_status "$HOME/.p10k.zsh" "synced Powerlevel10k config"
  check_file_status "$HOME/.config/nvim/init.lua" "synced Neovim config"
  check_file_status "$HOME/.config/wezterm/wezterm.lua" "synced WezTerm config"

  check_user_tool_status zoxide
  check_user_tool_status direnv
  check_tmux_status
  check_zsh_plugins_status
  check_nvim_plugins_status
  check_wezterm_status
  check_fonts_status
}

doctor_fix() {
  if [ "$need_packages" -eq 1 ]; then
    mark_warning "skipping OS package setup; run bin/dot install or bin/dot install --user"
  fi

  CHEZMOI=$(resolve_chezmoi)

  if [ "$need_sync" -eq 1 ]; then
    if has_command "$CHEZMOI"; then
      log "fix: syncing chezmoi source"
      sync_config
      refresh_user_path
    else
      mark_warning "skipping chezmoi sync because chezmoi is unavailable"
    fi
  fi

  if [ "$need_fonts" -eq 1 ]; then
    log "fix: installing bundled fonts"
    run_fonts install
  fi

  if [ "$need_tools" -eq 1 ]; then
    if has_command curl || has_command wget; then
      log "fix: installing user-local tools"
      run_tools install
      refresh_user_path
    else
      mark_warning "skipping user-local tools because curl or wget is unavailable"
    fi
  fi

  if [ "$need_tmux" -eq 1 ]; then
    log "fix: installing tmux setup"
    install_tmux_setup
    sync_tmux_config
  fi

  if [ "$need_zsh_plugins" -eq 1 ]; then
    log "fix: installing Antidote"
    install_zsh_setup
  fi

  if [ "$need_nvim_plugins" -eq 1 ]; then
    log "fix: installing Neovim plugins"
    install_nvim_setup
  fi
}

doctor() {
  fix=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fix|fix)
        fix=1
        ;;
      help|-h|--help)
        doctor_usage
        return 0
        ;;
      *)
        doctor_usage
        return 1
        ;;
    esac
    shift
  done

  doctor_check

  if [ "$fix" -eq 1 ] && [ "$failed" -ne 0 ]; then
    doctor_fix
    doctor_check
  fi

  return "$failed"
}

run_packages() {
  if [ -r /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease; then
    "$ROOT_DIR/packages/wsl.sh" "$@"
  elif [ "$(uname -s)" = "Linux" ]; then
    "$ROOT_DIR/packages/ubuntu.sh" "$@"
  else
    log "no package script is available for this platform"
    exit 1
  fi
}

run_user_packages() {
  run_packages user
}

run_zsh_plugins() {
  "$ROOT_DIR/scripts/install-antidote.sh" "$@"
}

run_fonts() {
  if [ "$(uname -s)" = "Linux" ]; then
    "$ROOT_DIR/scripts/install-fonts.sh" "$@"
  else
    log "no font script is available for this platform"
    exit 1
  fi
}

run_tools() {
  "$ROOT_DIR/scripts/install-user-tools.sh" "$@"
}

run_nvim() {
  "$ROOT_DIR/scripts/install-neovim-plugins.sh" "$@"
}

run_tmux() {
  "$ROOT_DIR/scripts/install-tmux-config.sh" "$@"
}

run_user_tools_if_needed() {
  command_name=$1

  run_tools "$command_name"
  refresh_user_path
}

install_tmux_setup() {
  if ! has_command tmux; then
    run_user_package_component tmux
    refresh_user_path
  fi

  if has_command git; then
    run_tmux install
  else
    mark_warning "skipping Oh my tmux install because git is unavailable"
  fi
}

update_tmux_setup() {
  if ! has_command git; then
    mark_warning "skipping Oh my tmux update because git is unavailable"
    return
  fi

  run_tmux update
}

install_zsh_setup() {
  if ! has_command git; then
    mark_warning "skipping zsh plugin install because git is unavailable"
    return
  fi

  run_zsh_plugins install

  if [ -r "$HOME/.config/zsh/plugins.txt" ] && has_command zsh; then
    run_zsh_plugins update
  else
    mark_warning "skipping zsh bundle sync because zsh or the plugin manifest is unavailable"
  fi
}

update_zsh_setup() {
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  plugin_file="${ZSH_PLUGIN_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/zsh/plugins.txt}"

  if [ -d "$antidote_dir/.git" ] && [ -r "$plugin_file" ] && has_command zsh; then
    run_zsh_plugins update
  else
    mark_warning "skipping zsh plugin update because Antidote, zsh, or the plugin manifest is unavailable"
  fi
}

install_nvim_setup() {
  plugin_id=${1:-all}

  if has_command nvim; then
    run_nvim install "$plugin_id"
  else
    mark_warning "skipping Neovim plugin install because nvim is unavailable"
  fi
}

update_nvim_setup() {
  plugin_id=${1:-all}

  if has_command nvim; then
    run_nvim update "$plugin_id"
  else
    mark_warning "skipping Neovim plugin update because nvim is unavailable"
  fi
}

install_setup() {
  install_mode=system

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --user|user)
        install_mode=user
        ;;
      help|-h|--help)
        install_usage
        return 0
        ;;
      *)
        install_usage
        return 1
        ;;
    esac
    shift
  done

  if [ "$install_mode" = "user" ]; then
    log "installing user-local setup"
    run_user_packages
  else
    log "installing platform package setup"
    run_packages install
  fi

  refresh_user_path

  log "syncing configuration"
  sync_config
  refresh_user_path

  log "installing bundled fonts"
  run_fonts install

  if [ "$install_mode" != "user" ]; then
    log "installing user-local tools"
    run_user_tools_if_needed install
  fi

  log "installing Oh my tmux"
  install_tmux_setup

  log "installing zsh plugins"
  install_zsh_setup

  log "installing Neovim plugins"
  install_nvim_setup

  log "checking setup"
  doctor
}

update_repo() {
  update_action=status
  update_component_id=

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --check|check)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        update_action=check
        ;;
      --raw|raw)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        update_action=raw
        ;;
      --sync|sync)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=sync
        update_component_id=$2
        shift
        ;;
      --install|install)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=install
        update_component_id=$2
        shift
        ;;
      --update|update)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=update
        update_component_id=$2
        shift
        ;;
      --build|build)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=build
        update_component_id=$2
        shift
        ;;
      help|-h|--help)
        update_usage
        return 0
        ;;
      *)
        update_usage
        return 1
        ;;
    esac
    shift
  done

  if [ "$update_action" != "status" ]; then
    if [ "$update_action" = "check" ]; then
      refresh_user_path
      log "component status"
      component_status_table
      return
    fi

    if [ "$update_action" = "raw" ]; then
      refresh_user_path
      component_rows
      return
    fi

    run_component_action "$update_action" "$update_component_id"
    return
  fi

  pull_repository
  refresh_user_path

  log "component status"
  component_status_table
}

command_name="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command_name" in
  bootstrap)
    "$ROOT_DIR/bootstrap.sh" "$@"
    ;;
  install)
    install_setup "$@"
    ;;
  tui)
    run_tui "$@"
    ;;
  sync)
    case "${1:-}" in
      help|-h|--help)
        sync_usage
        exit 0
        ;;
      "")
        ;;
      *)
        sync_usage
        exit 1
        ;;
    esac
    sync_config
    ;;
  dev-ref)
    dev_ref_command "$@"
    ;;
  dev-apply)
    if [ "$#" -ne 0 ]; then
      log "usage: dot dev-apply"
      exit 1
    fi
    dev_apply
    ;;
  doctor)
    doctor "$@"
    ;;
  update)
    update_repo "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
