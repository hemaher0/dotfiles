#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
SOURCE_DIR="${DOTFILES_SOURCE_DIR:-$ROOT_DIR/home}"

usage() {
  cat <<'EOF'
Usage: dot <command>

Commands:
  install [--user]
             Install the complete dotfiles setup
  update     Pull the repository, then show component status
  doctor [--fix]
             Check local requirements and optionally repair user setup
  sync       Sync the chezmoi source directory
  bootstrap  Run the repository bootstrap script
  help       Show this help
EOF
}

has_command() {
  if [ -x "$1" ] && case "$1" in */*) true ;; *) false ;; esac; then
    return 0
  fi

  command -v "$1" >/dev/null 2>&1
}

log() {
  printf '%s\n' "dotfiles: $*"
}

is_wsl() {
  [ -r /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease
}

resolve_chezmoi() {
  if [ -n "${CHEZMOI:-}" ]; then
    printf '%s\n' "$CHEZMOI"
  elif has_command chezmoi; then
    printf '%s\n' "chezmoi"
  elif [ -x "$HOME/.local/bin/chezmoi" ]; then
    printf '%s\n' "$HOME/.local/bin/chezmoi"
  elif [ -x "$ROOT_DIR/.local/bin/chezmoi" ]; then
    printf '%s\n' "$ROOT_DIR/.local/bin/chezmoi"
  else
    printf '%s\n' "chezmoi"
  fi
}

require_chezmoi() {
  CHEZMOI=$(resolve_chezmoi)

  if ! has_command "$CHEZMOI"; then
    log "chezmoi is not installed"
    exit 1
  fi
}

sync_config() {
  require_chezmoi

  if [ ! -d "$SOURCE_DIR" ]; then
    log "chezmoi source directory is not ready: $SOURCE_DIR"
    return 0
  fi

  "$CHEZMOI" --source "$SOURCE_DIR" apply
}

sync_tmux_config() {
  require_chezmoi

  if [ ! -d "$SOURCE_DIR" ]; then
    log "chezmoi source directory is not ready: $SOURCE_DIR"
    return 0
  fi

  "$CHEZMOI" --source "$SOURCE_DIR" apply \
    "$HOME/.config/tmux/tmux.conf" \
    "$HOME/.config/tmux/tmux.conf.local"
}

refresh_user_path() {
  for path_dir in "$HOME/.local/bin" "$HOME/.cargo/bin" "$HOME/bin"; do
    if [ -d "$path_dir" ] && case ":${PATH:-}:" in *":$path_dir:"*) false ;; *) true ;; esac; then
      PATH="$path_dir:${PATH:-}"
      export PATH
    fi
  done
}

doctor_usage() {
  cat <<'EOF'
Usage: dot doctor [--fix]

Checks the local dotfiles setup. With --fix, repairs supported user-managed
components. It does not install OS packages.
EOF
}

install_usage() {
  cat <<'EOF'
Usage: dot install [--user]

Installs the complete dotfiles setup. The default install uses the detected
platform package manager and may ask for sudo. With --user, installs supported
components into the user profile without sudo.
EOF
}

sync_usage() {
  cat <<'EOF'
Usage: dot sync

Syncs the chezmoi source directory into the home directory.
EOF
}

update_usage() {
  cat <<'EOF'
Usage:
  dot update
  dot update --install <id>
  dot update --update <id>
  dot update --build <id>

Without options, pulls the repository, then prints a component status table with
stable IDs. Action options run against the current checkout and then print the
component status table.
EOF
}

status_value() {
  value=$1

  if [ -n "$value" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "-"
  fi
}

command_version() {
  component_name=$1
  command_name=$2

  case "$component_name" in
    direnv)
      version_output=$("$command_name" version 2>/dev/null || true)
      ;;
    tmux)
      version_output=$("$command_name" -V 2>/dev/null || true)
      ;;
    *)
      version_output=$("$command_name" --version 2>/dev/null || true)
      ;;
  esac

  printf '%s\n' "$version_output" \
    | sed -n '1{s/^[^0-9]*//;s/[[:space:],].*$//;p;}'
}

repo_version() {
  repo_dir=$1

  if ! git -C "$repo_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return
  fi

  repo_branch=$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
  repo_sha=$(git -C "$repo_dir" rev-parse --short HEAD 2>/dev/null || true)

  if [ -n "$repo_branch" ] && [ -n "$repo_sha" ]; then
    printf '%s@%s\n' "$repo_branch" "$repo_sha"
  fi
}

first_available_command() {
  commands=$1
  old_ifs=$IFS
  IFS=,

  for command_name in $commands; do
    if has_command "$command_name"; then
      IFS=$old_ifs
      printf '%s\n' "$command_name"
      return 0
    fi
  done

  IFS=$old_ifs
  return 1
}

font_installed() {
  font_name=$1

  has_command fc-list && fc-list 2>/dev/null | grep -qi "$font_name"
}

font_current() {
  font_name=$1

  if has_command fc-match; then
    fc_match=$(fc-match "$font_name" 2>/dev/null || true)
    printf '%s\n' "$fc_match" | sed -n '1{s/:.*$//;p;}'
  fi
}

component_registry() {
  CHEZMOI=$(resolve_chezmoi)
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  antidote_home="${ANTIDOTE_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}/antidote}"
  nvim_lazy_dir="${XDG_DATA_HOME:-$HOME/.local/share}/nvim/lazy"

  cat <<EOF
repo-dotfiles|dotfiles repo|repo|git|repo|$ROOT_DIR
package-git|git|system|package|command|git
package-chezmoi|chezmoi|system|package|command|$CHEZMOI
package-zsh|zsh|system/user|package/source|command|zsh
package-tmux|tmux|system/user|package/source|command|tmux
package-ncurses|ncurses|user|source|ncurses|${USER_PREFIX:-$HOME/.local}
package-nvim|nvim|system/user|package/prebuilt|command|nvim
package-rustc|rustc|system/user|package/rustup|command|rustc
package-cargo|cargo|system/user|package/rustup|command|cargo
package-downloader|curl or wget|system|package|any-command|curl,wget
tool-zoxide|zoxide|user|prebuilt|command|zoxide
tool-direnv|direnv|user|prebuilt|command|direnv
config-zshrc|synced zshrc|config|chezmoi|file|$HOME/.zshrc
config-zshenv|synced zshenv|config|chezmoi|file|$HOME/.zshenv
config-p10k|synced Powerlevel10k config|config|chezmoi|file|$HOME/.p10k.zsh
config-nvim|synced Neovim config|config|chezmoi|file|$HOME/.config/nvim/init.lua
config-wezterm|synced WezTerm config|config|chezmoi|file|$HOME/.config/wezterm/wezterm.lua
config-tmux|managed tmux config|config|chezmoi|symlink|$HOME/.config/tmux/tmux.conf
config-tmux-local|managed tmux local config|config|chezmoi|file|$HOME/.config/tmux/tmux.conf.local
tmux-oh-my|Oh my tmux checkout|tmux config|git|dir|${OH_MY_TMUX_DIR:-$HOME/.local/share/oh-my-tmux}
zsh-antidote|Antidote|zsh plugin|git|file|$antidote_dir/antidote.zsh
zsh-manifest|zsh plugin manifest|zsh plugin|chezmoi|file|$HOME/.config/zsh/plugins.txt
zsh-powerlevel10k|zsh plugin: powerlevel10k|zsh plugin|antidote|dir|$antidote_home/github.com/romkatv/powerlevel10k
zsh-forgit|zsh plugin: forgit|zsh plugin|antidote|dir|$antidote_home/github.com/wfxr/forgit
zsh-vi-mode|zsh plugin: zsh-vi-mode|zsh plugin|antidote|dir|$antidote_home/github.com/jeffreytse/zsh-vi-mode
nvim-lazy|Neovim plugin: lazy.nvim|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/lazy.nvim
nvim-smart-splits|Neovim plugin: smart-splits.nvim|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/smart-splits.nvim
nvim-blink-cmp|Neovim plugin: blink.cmp|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/blink.cmp
nvim-neo-tree|Neovim plugin: neo-tree.nvim|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/neo-tree.nvim
nvim-treesitter|Neovim plugin: nvim-treesitter|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/nvim-treesitter
nvim-mason|Neovim plugin: mason.nvim|nvim plugin|lazy.nvim|dir|$nvim_lazy_dir/mason.nvim
EOF

  printf '%s\n' "font-red-hat-mono|Red Hat Mono|font|fontconfig|font|Red Hat Mono"
  printf '%s\n' "font-d2coding-ligature|D2CodingLigature Nerd Font|font|fontconfig|font|D2CodingLigature Nerd Font"
}

ncurses_current() {
  user_prefix=$1

  for config_tool in "$user_prefix/bin/ncursesw6-config" "$user_prefix/bin/ncurses6-config"; do
    if [ -x "$config_tool" ]; then
      "$config_tool" --version 2>/dev/null || true
      return
    fi
  done

  for lib_dir in "$user_prefix/lib" "$user_prefix/lib64"; do
    for lib_name in libncursesw.so libncursesw.a libncurses.so libncurses.a; do
      if [ -r "$lib_dir/$lib_name" ]; then
        printf '%s\n' "present"
        return
      fi
    done
  done
}

component_status_row() {
  status=$1
  component_id=$2
  component_name=$3
  scope=$4
  method=$5
  current=$6
  action=$7

  printf '%-8s %-26s %-34s %-12s %-16s %-16s %s\n' \
    "$status" "$component_id" "$component_name" "$scope" "$method" "$(status_value "$current")" "$action"
}

component_status_table() {
  printf '%-8s %-26s %-34s %-12s %-16s %-16s %s\n' \
    "STATUS" "ID" "COMPONENT" "SCOPE" "METHOD" "CURRENT" "ACTION"
  printf '%-8s %-26s %-34s %-12s %-16s %-16s %s\n' \
    "------" "--" "---------" "-----" "------" "-------" "------"

  component_registry | while IFS='|' read -r component_id component_name scope method kind target; do
    status=missing
    current=
    next_action="bin/dot update --install $component_id"

    case "$kind" in
      repo)
        if current=$(repo_version "$target"); then
          status=ok
          next_action=-
        fi
        ;;
      ncurses)
        current=$(ncurses_current "$target")
        if [ -n "$current" ]; then
          status=ok
          next_action=-
        fi
        ;;
      command)
        if has_command "$target"; then
          status=ok
          current=$(command_version "$component_name" "$target")
          next_action=-
        fi
        ;;
      any-command)
        if command_name=$(first_available_command "$target"); then
          status=ok
          current=$command_name
          next_action=-
        fi
        ;;
      file)
        if [ -r "$target" ]; then
          status=ok
          current=present
          next_action=-
        fi
        ;;
      symlink)
        if [ -L "$target" ] && [ -r "$target" ]; then
          status=ok
          current=present
          next_action=-
        elif [ -L "$target" ]; then
          current=target-missing
          case "$component_id" in
            config-tmux)
              next_action="bin/dot update --install tmux-oh-my"
              ;;
          esac
        fi
        ;;
      dir)
        if [ -d "$target" ]; then
          status=ok
          current=present
          next_action=-
        fi
        ;;
      font)
        if ! has_command fc-list; then
          status=unknown
          next_action="bin/dot install"
        elif font_installed "$target"; then
          status=ok
          current=$(font_current "$target")
          next_action=-
        fi
        ;;
    esac

    component_status_row "$status" "$component_id" "$component_name" "$scope" "$method" "$current" "$next_action"
  done
}

component_row() {
  component_id=$1

  component_registry | awk -F '|' -v component_id="$component_id" '
    $1 == component_id {
      print
      found = 1
      exit
    }
    END {
      exit found ? 0 : 1
    }
  '
}

list_component_ids() {
  component_registry | sed 's/|.*//'
}

require_component_id() {
  component_id=$1

  if component_row "$component_id" >/dev/null; then
    return 0
  fi

  log "unknown component id: $component_id"
  log "known component ids:"
  list_component_ids | sed 's/^/  /'
  return 1
}

pull_repository() {
  if ! has_command git; then
    log "git is required for update"
    exit 1
  fi

  log "updating repository"
  git -C "$ROOT_DIR" pull --ff-only
}

run_user_package_component() {
  component_name=$1

  run_packages "user-$component_name"
}

run_forced_user_package_component() {
  component_name=$1
  old_force=${DOTFILES_FORCE_USER_INSTALL:-}

  DOTFILES_FORCE_USER_INSTALL=1
  export DOTFILES_FORCE_USER_INSTALL
  run_user_package_component "$component_name"

  if [ -n "$old_force" ]; then
    DOTFILES_FORCE_USER_INSTALL=$old_force
    export DOTFILES_FORCE_USER_INSTALL
  else
    unset DOTFILES_FORCE_USER_INSTALL
  fi
}

unsupported_component_action() {
  action_name=$1
  component_id=$2

  log "$action_name is not supported for component: $component_id"
  return 1
}

install_component() {
  component_id=$1

  case "$component_id" in
    repo-dotfiles)
      pull_repository
      ;;
    package-git|package-downloader)
      run_packages install
      ;;
    package-chezmoi)
      run_user_package_component chezmoi
      ;;
    package-zsh)
      run_user_package_component zsh
      ;;
    package-tmux)
      run_user_package_component tmux
      ;;
    package-ncurses)
      run_user_package_component ncurses
      ;;
    package-nvim)
      run_user_package_component nvim
      ;;
    package-rustc|package-cargo)
      run_user_package_component rust
      ;;
    tool-zoxide)
      run_tools install zoxide
      refresh_user_path
      ;;
    tool-direnv)
      run_tools install direnv
      refresh_user_path
      ;;
    config-tmux|config-tmux-local)
      sync_tmux_config
      refresh_user_path
      ;;
    config-*|zsh-manifest)
      sync_config
      refresh_user_path
      ;;
    tmux-oh-my)
      install_tmux_setup
      sync_tmux_config
      refresh_user_path
      ;;
    font-*)
      run_fonts install
      ;;
    zsh-*)
      install_zsh_setup
      ;;
    nvim-*)
      install_nvim_setup
      ;;
    *)
      unsupported_component_action install "$component_id"
      ;;
  esac
}

update_component() {
  component_id=$1

  case "$component_id" in
    repo-dotfiles)
      pull_repository
      ;;
    package-git|package-downloader)
      run_packages upgrade
      ;;
    package-chezmoi)
      run_user_package_component chezmoi
      ;;
    package-zsh)
      run_forced_user_package_component zsh
      ;;
    package-tmux)
      run_forced_user_package_component tmux
      ;;
    package-ncurses)
      run_forced_user_package_component ncurses
      ;;
    package-nvim)
      run_forced_user_package_component nvim
      ;;
    package-rustc|package-cargo)
      run_user_package_component rust
      ;;
    tool-zoxide)
      run_tools update zoxide
      refresh_user_path
      ;;
    tool-direnv)
      run_tools update direnv
      refresh_user_path
      ;;
    config-tmux|config-tmux-local)
      sync_tmux_config
      refresh_user_path
      ;;
    config-*|zsh-manifest)
      sync_config
      refresh_user_path
      ;;
    font-*)
      run_fonts update
      ;;
    tmux-oh-my)
      update_tmux_setup
      ;;
    zsh-*)
      update_zsh_setup
      ;;
    nvim-*)
      update_nvim_setup
      ;;
    *)
      unsupported_component_action update "$component_id"
      ;;
  esac
}

build_component() {
  component_id=$1

  case "$component_id" in
    package-zsh)
      run_forced_user_package_component zsh
      ;;
    package-ncurses)
      run_forced_user_package_component ncurses
      ;;
    package-tmux)
      run_forced_user_package_component tmux
      ;;
    *)
      unsupported_component_action build "$component_id"
      ;;
  esac
}

run_component_action() {
  action_name=$1
  component_id=$2

  require_component_id "$component_id"

  log "$action_name component: $component_id"
  case "$action_name" in
    install)
      install_component "$component_id"
      ;;
    update)
      update_component "$component_id"
      ;;
    build)
      build_component "$component_id"
      ;;
    *)
      log "unknown update action: $action_name"
      return 1
      ;;
  esac

  refresh_user_path
  log "component status"
  component_status_table
}

mark_missing() {
  log "missing: $1"
  failed=1
}

mark_warning() {
  log "warning: $1"
}

check_command_status() {
  command_name=$1
  install_group=$2

  if has_command "$command_name"; then
    log "ok: command $command_name"
    return
  fi

  mark_missing "command $command_name"

  case "$install_group" in
    packages) need_packages=1 ;;
    tools) need_tools=1 ;;
    none) ;;
  esac
}

check_file_status() {
  file_path=$1
  description=$2

  if [ -r "$file_path" ]; then
    log "ok: $description"
  else
    mark_missing "$description"
    need_sync=1
  fi
}

check_user_tool_status() {
  command_name=$1
  tool_path="$HOME/.local/bin/$command_name"

  if has_command "$command_name"; then
    log "ok: command $command_name"
  elif [ -x "$tool_path" ]; then
    mark_missing "command $command_name is installed but not on PATH: $tool_path"
    need_sync=1
  else
    mark_missing "command $command_name"
    need_tools=1
  fi
}

check_fontconfig_font() {
  font_name=$1

  if fc-list 2>/dev/null | grep -qi "$font_name"; then
    log "ok: font $font_name"
  else
    mark_missing "font $font_name"
    need_fonts=1
  fi
}

check_fonts_status() {
  if has_command fc-list; then
    check_fontconfig_font "Red Hat Mono"
    check_fontconfig_font "D2CodingLigature Nerd Font"
  else
    mark_missing "command fc-list"
    need_packages=1
    need_fonts=1
  fi

  if has_command wezterm; then
    wezterm_fonts=$(wezterm ls-fonts 2>/dev/null || true)
    if printf '%s\n' "$wezterm_fonts" | grep -q "Red Hat Mono" \
      && printf '%s\n' "$wezterm_fonts" | grep -q "D2CodingLigature Nerd Font"; then
      log "ok: WezTerm font fallback"
    else
      mark_warning "WezTerm did not report both preferred fonts"
    fi
  fi
}

check_zsh_plugins_status() {
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  antidote_home="${ANTIDOTE_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}/antidote}"

  if [ -r "$antidote_dir/antidote.zsh" ]; then
    log "ok: Antidote script"
  else
    mark_missing "Antidote script"
    need_zsh_plugins=1
  fi

  check_file_status "$HOME/.config/zsh/plugins.txt" "zsh plugin manifest"

  for bundle in \
    github.com/romkatv/powerlevel10k \
    github.com/wfxr/forgit \
    github.com/jeffreytse/zsh-vi-mode
  do
    if [ -d "$antidote_home/$bundle" ]; then
      log "ok: zsh bundle $bundle"
    else
      mark_missing "zsh bundle $bundle"
      need_zsh_plugins=1
    fi
  done
}

check_nvim_plugins_status() {
  nvim_lazy_dir="${XDG_DATA_HOME:-$HOME/.local/share}/nvim/lazy"

  for plugin in \
    lazy.nvim \
    smart-splits.nvim \
    blink.cmp \
    neo-tree.nvim \
    nvim-treesitter \
    mason.nvim
  do
    if [ -d "$nvim_lazy_dir/$plugin" ]; then
      log "ok: Neovim plugin $plugin"
    else
      mark_missing "Neovim plugin $plugin"
      need_nvim_plugins=1
    fi
  done
}

check_tmux_status() {
  oh_my_tmux_dir="${OH_MY_TMUX_DIR:-$HOME/.local/share/oh-my-tmux}"

  if has_command tmux; then
    log "ok: command tmux"
  else
    mark_missing "command tmux"
    need_tmux=1
  fi

  if [ -d "$oh_my_tmux_dir/.git" ]; then
    log "ok: Oh my tmux checkout"
  else
    mark_missing "Oh my tmux checkout"
    need_tmux=1
  fi

  if [ -L "$HOME/.config/tmux/tmux.conf" ] && [ -r "$HOME/.config/tmux/tmux.conf" ]; then
    log "ok: managed tmux config"
  else
    mark_missing "managed tmux config"
    need_tmux=1
  fi

  if [ -r "$HOME/.config/tmux/tmux.conf.local" ]; then
    log "ok: managed tmux local config"
  else
    mark_missing "managed tmux local config"
    need_tmux=1
  fi
}

check_wezterm_status() {
  if ! has_command wezterm; then
    mark_warning "wezterm command is not installed in this environment"
    return
  fi

  log "ok: command wezterm"

  if wezterm cli adjust-pane-size --help >/dev/null 2>&1; then
    log "ok: WezTerm pane resize CLI"
  else
    mark_missing "WezTerm pane resize CLI"
  fi

  if wezterm show-keys --lua >/dev/null 2>&1; then
    log "ok: WezTerm config loads"
  else
    mark_missing "WezTerm config loads"
  fi
}

doctor_check() {
  failed=0
  need_sync=0
  need_fonts=0
  need_nvim_plugins=0
  need_packages=0
  need_tmux=0
  need_tools=0
  need_zsh_plugins=0

  refresh_user_path
  CHEZMOI=$(resolve_chezmoi)

  check_command_status git packages
  check_command_status "$CHEZMOI" packages
  check_command_status zsh packages
  check_command_status nvim packages
  check_command_status rustc packages
  check_command_status cargo packages

  if has_command curl || has_command wget; then
    log "ok: curl or wget"
  else
    mark_missing "curl or wget"
    need_packages=1
  fi

  if [ -d "$SOURCE_DIR" ]; then
    log "ok: chezmoi source $SOURCE_DIR"
  else
    mark_missing "chezmoi source $SOURCE_DIR"
  fi

  check_file_status "$HOME/.zshrc" "synced zshrc"
  check_file_status "$HOME/.zshenv" "synced zshenv"
  check_file_status "$HOME/.p10k.zsh" "synced Powerlevel10k config"
  check_file_status "$HOME/.config/nvim/init.lua" "synced Neovim config"
  check_file_status "$HOME/.config/wezterm/wezterm.lua" "synced WezTerm config"

  check_user_tool_status zoxide
  check_user_tool_status direnv
  check_tmux_status
  check_zsh_plugins_status
  check_nvim_plugins_status
  check_wezterm_status
  check_fonts_status
}

doctor_fix() {
  if [ "$need_packages" -eq 1 ]; then
    mark_warning "skipping OS package setup; run bin/dot install or bin/dot install --user"
  fi

  CHEZMOI=$(resolve_chezmoi)

  if [ "$need_sync" -eq 1 ]; then
    if has_command "$CHEZMOI"; then
      log "fix: syncing chezmoi source"
      sync_config
      refresh_user_path
    else
      mark_warning "skipping chezmoi sync because chezmoi is unavailable"
    fi
  fi

  if [ "$need_fonts" -eq 1 ]; then
    log "fix: installing bundled fonts"
    run_fonts install
  fi

  if [ "$need_tools" -eq 1 ]; then
    if has_command curl || has_command wget; then
      log "fix: installing user-local tools"
      run_tools install
      refresh_user_path
    else
      mark_warning "skipping user-local tools because curl or wget is unavailable"
    fi
  fi

  if [ "$need_tmux" -eq 1 ]; then
    log "fix: installing tmux setup"
    install_tmux_setup
    sync_tmux_config
  fi

  if [ "$need_zsh_plugins" -eq 1 ]; then
    log "fix: installing Antidote"
    install_zsh_setup
  fi

  if [ "$need_nvim_plugins" -eq 1 ]; then
    log "fix: installing Neovim plugins"
    install_nvim_setup
  fi
}

doctor() {
  fix=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fix|fix)
        fix=1
        ;;
      help|-h|--help)
        doctor_usage
        return 0
        ;;
      *)
        doctor_usage
        return 1
        ;;
    esac
    shift
  done

  doctor_check

  if [ "$fix" -eq 1 ] && [ "$failed" -ne 0 ]; then
    doctor_fix
    doctor_check
  fi

  return "$failed"
}

run_packages() {
  if [ -r /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease; then
    "$ROOT_DIR/packages/wsl.sh" "$@"
  elif [ "$(uname -s)" = "Linux" ]; then
    "$ROOT_DIR/packages/ubuntu.sh" "$@"
  else
    log "no package script is available for this platform"
    exit 1
  fi
}

run_user_packages() {
  run_packages user
}

run_zsh_plugins() {
  "$ROOT_DIR/scripts/install-antidote.sh" "$@"
}

run_fonts() {
  if [ "$(uname -s)" = "Linux" ]; then
    "$ROOT_DIR/scripts/install-fonts.sh" "$@"
  else
    log "no font script is available for this platform"
    exit 1
  fi
}

run_tools() {
  "$ROOT_DIR/scripts/install-user-tools.sh" "$@"
}

run_nvim() {
  "$ROOT_DIR/scripts/install-neovim-plugins.sh" "$@"
}

run_tmux() {
  "$ROOT_DIR/scripts/install-tmux-config.sh" "$@"
}

run_user_tools_if_needed() {
  command_name=$1

  run_tools "$command_name"
  refresh_user_path
}

install_tmux_setup() {
  if ! has_command tmux; then
    run_user_package_component tmux
    refresh_user_path
  fi

  if has_command git; then
    run_tmux install
  else
    mark_warning "skipping Oh my tmux install because git is unavailable"
  fi
}

update_tmux_setup() {
  if ! has_command git; then
    mark_warning "skipping Oh my tmux update because git is unavailable"
    return
  fi

  run_tmux update
}

install_zsh_setup() {
  if ! has_command git; then
    mark_warning "skipping zsh plugin install because git is unavailable"
    return
  fi

  run_zsh_plugins install

  if [ -r "$HOME/.config/zsh/plugins.txt" ] && has_command zsh; then
    run_zsh_plugins update
  else
    mark_warning "skipping zsh bundle sync because zsh or the plugin manifest is unavailable"
  fi
}

update_zsh_setup() {
  antidote_dir="${ANTIDOTE_DIR:-${ZDOTDIR:-$HOME}/.antidote}"
  plugin_file="${ZSH_PLUGIN_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/zsh/plugins.txt}"

  if [ -d "$antidote_dir/.git" ] && [ -r "$plugin_file" ] && has_command zsh; then
    run_zsh_plugins update
  else
    mark_warning "skipping zsh plugin update because Antidote, zsh, or the plugin manifest is unavailable"
  fi
}

install_nvim_setup() {
  if has_command nvim; then
    run_nvim install
  else
    mark_warning "skipping Neovim plugin install because nvim is unavailable"
  fi
}

update_nvim_setup() {
  if has_command nvim; then
    run_nvim update
  else
    mark_warning "skipping Neovim plugin update because nvim is unavailable"
  fi
}

install_setup() {
  install_mode=system

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --user|user)
        install_mode=user
        ;;
      help|-h|--help)
        install_usage
        return 0
        ;;
      *)
        install_usage
        return 1
        ;;
    esac
    shift
  done

  if [ "$install_mode" = "user" ]; then
    log "installing user-local setup"
    run_user_packages
  else
    log "installing platform package setup"
    run_packages install
  fi

  refresh_user_path

  log "syncing configuration"
  sync_config
  refresh_user_path

  log "installing bundled fonts"
  run_fonts install

  if [ "$install_mode" != "user" ]; then
    log "installing user-local tools"
    run_user_tools_if_needed install
  fi

  log "installing Oh my tmux"
  install_tmux_setup

  log "installing zsh plugins"
  install_zsh_setup

  log "installing Neovim plugins"
  install_nvim_setup

  log "checking setup"
  doctor
}

update_repo() {
  update_action=status
  update_component_id=

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --install|install)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=install
        update_component_id=$2
        shift
        ;;
      --update|update)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=update
        update_component_id=$2
        shift
        ;;
      --build|build)
        if [ "$update_action" != "status" ]; then
          update_usage
          return 1
        fi
        if [ -z "${2:-}" ]; then
          log "$1 requires a component id"
          update_usage
          return 1
        fi
        update_action=build
        update_component_id=$2
        shift
        ;;
      help|-h|--help)
        update_usage
        return 0
        ;;
      *)
        update_usage
        return 1
        ;;
    esac
    shift
  done

  if [ "$update_action" != "status" ]; then
    run_component_action "$update_action" "$update_component_id"
    return
  fi

  pull_repository
  refresh_user_path

  log "component status"
  component_status_table
}

command_name="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command_name" in
  bootstrap)
    "$ROOT_DIR/bootstrap.sh" "$@"
    ;;
  install)
    install_setup "$@"
    ;;
  sync)
    case "${1:-}" in
      help|-h|--help)
        sync_usage
        exit 0
        ;;
      "")
        ;;
      *)
        sync_usage
        exit 1
        ;;
    esac
    sync_config
    ;;
  doctor)
    doctor "$@"
    ;;
  update)
    update_repo "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
